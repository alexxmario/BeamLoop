{
  "expo": {
    "name": "BeamLoop",
    "slug": "beamloop",
    "version": "1.0.0",
    "description": "Publish videos and photos to all your connected social accounts from one place.",
    "scheme": "beamloop",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0C121A",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.beamloop.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.beamloop.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "BeamLoop needs access to your photos and videos so you can publish them to your social accounts.",
          "microphonePermission": false
        }
      ],
      "expo-font"
    ]
  }
}
