# Post for Me — our social publishing provider. Backend only, never ship to
# the client. Get a key at https://www.postforme.dev
POSTFORME_API_KEY=your-post-for-me-api-key
POSTFORME_BASE_URL=https://api.postforme.dev

# Secret used to sign BeamLoop's own session JWTs (any long random string)
APP_JWT_SECRET=change-me-to-a-long-random-string

# The deep link the platform login returns to. Must ALSO be set as the
# Project Redirect URL in the Post for Me dashboard (the free plan doesn't
# allow a per-request override). Must match the mobile app's scheme.
CONNECT_REDIRECT_URL=beamloop://connections/callback

# Optional: allow a comma-separated list of browser origins. Leave unset to
# deny browser cross-origin requests; the native app sends no Origin header.
# CORS_ORIGIN=https://beamloop.app,https://www.beamloop.app

# Public website and App Store contact details. Set PUBLIC_LEGAL_NAME and
# SUPPORT_EMAIL to the exact identity and monitored inbox users should see.
PUBLIC_LEGAL_NAME=Alex Ionescu
SUPPORT_EMAIL=alexionescu870@gmail.com
PUBLIC_BASE_URL=https://beamloop-production.up.railway.app
# Add this after the App Store listing is live.
# APP_STORE_URL=https://apps.apple.com/app/id1234567890

# Where the SQLite DB and retry media are stored. Defaults to ./data.
# In production point this at a mounted persistent volume.
# DATA_DIR=/app/data

# Delete retained retry media after this many hours (default: 168 / 7 days).
MEDIA_RETENTION_HOURS=168

PORT=3001
